---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import RubricLabel from '../components/RubricLabel.astro';
import TickerBar from '../components/TickerBar.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import {
	getArticleTypeLabel,
	getPostHref,
	getPrimaryRubric,
	getReadingTimeLabel,
	getToneClass,
	getVisiblePosts,
	sortPosts,
} from '../lib/site';

const posts = sortPosts(getVisiblePosts(await getCollection('posts')));
const leadPost = posts[0];
const latestPosts = posts.slice(1, 10);
const opinionPosts = posts.filter((p) => p.data.articleType !== 'news').slice(0, 3);
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<TickerBar />

		<main class="main-shell">

			{leadPost && (
				<article class="lead-story">
					<a
						href={getPostHref(leadPost)}
						class:list={['lead-story__media', `media-surface--${getToneClass(0)}`]}
					></a>
					<div class="lead-story__body">
						<div class="lead-story__meta">
							<span class="content-tag"><RubricLabel name={getPrimaryRubric(leadPost)} /></span>
							<span>{getArticleTypeLabel(leadPost)}</span>
							<span>{getReadingTimeLabel(leadPost)}</span>
						</div>
						<h1 class="lead-story__title">
							<a href={getPostHref(leadPost)}>{leadPost.data.title}</a>
						</h1>
						<p class="lead-story__desc">{leadPost.data.description}</p>
						<time class="lead-story__date">
							{leadPost.data.pubDate.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' })}
						</time>
					</div>
				</article>
			)}

			<section class="post-stream">
				{latestPosts.map((post) => (
					<a class="post-row" href={getPostHref(post)}>
						<time class="post-row__date">
							{post.data.pubDate.toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' })}
						</time>
						<span class="post-row__rubric"><RubricLabel name={getPrimaryRubric(post)} /></span>
						<strong class="post-row__title">{post.data.title}</strong>
						<em class="post-row__type">{getArticleTypeLabel(post)}</em>
					</a>
				))}
				<a class="post-stream__more" href="/blog">Все публикации →</a>
			</section>

			{opinionPosts.length > 0 && (
				<section class="opinion-grid">
					{opinionPosts.map((post, index) => (
						<article class="opinion-card">
							<div class="feed-list__meta">
								<RubricLabel name={getPrimaryRubric(post)} />
								<span>{getArticleTypeLabel(post)}</span>
							</div>
							<a href={getPostHref(post)} class:list={['media-surface', `media-surface--${getToneClass(index + 1)}`]}></a>
							<h3><a href={getPostHref(post)}>{post.data.title}</a></h3>
							<div class="opinion-card__meta">
								<span>{post.data.pubDate.toLocaleDateString('ru-RU')}</span>
								<span>{getReadingTimeLabel(post)}</span>
							</div>
						</article>
					))}
				</section>
			)}

		</main>

		<Footer />
	</body>
</html>
