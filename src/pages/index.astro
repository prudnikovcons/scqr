---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PostThumbnail from '../components/PostThumbnail.astro';
import RubricLabel from '../components/RubricLabel.astro';
import TickerBar from '../components/TickerBar.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import {
	buildClusterSummary,
	buildRubricSummary,
	getFeaturePosts,
	getArticleTypeLabel,
	getClusterHref,
	getPostHref,
	getPrimaryRubric,
	getReadingTimeLabel,
	getRubricHref,
	getToneClass,
	getVisiblePosts,
	sortPosts,
} from '../lib/site';

const posts = sortPosts(getVisiblePosts(await getCollection('posts')));
const featurePosts = getFeaturePosts(posts, 5);
const leadPost = featurePosts[0] ?? posts[0];
const visualFrontPosts = featurePosts.slice(1, 5);
const newsPosts = posts.filter((p) => p.data.articleType === 'news').slice(0, 7);
const analysisPosts = posts.filter((p) => p.data.articleType === 'analysis').slice(0, 5);
const columnPosts = posts.filter((p) => p.data.articleType === 'column').slice(0, 3);
const clusterPosts = buildClusterSummary(posts).slice(0, 3);
const rubricSummary = buildRubricSummary(posts).filter((r) => r.slug);
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image={leadPost?.data.heroImage} />
	</head>
	<body>
		<Header />
		<TickerBar />

		<main class="main-shell">

			{leadPost && (
				<article class="lead-story">
					<PostThumbnail post={leadPost} className="lead-story__media" toneClass={getToneClass(0)} />
					<div class="lead-story__body">
						<div class="lead-story__meta">
							<span class="content-tag"><RubricLabel name={getPrimaryRubric(leadPost)} /></span>
							<span>{getArticleTypeLabel(leadPost)}</span>
							<span>{getReadingTimeLabel(leadPost)}</span>
						</div>
						<h1 class="lead-story__title">
							<a href={getPostHref(leadPost)}>{leadPost.data.title}</a>
						</h1>
						<p class="lead-story__desc">{leadPost.data.description}</p>
						<time class="lead-story__date">
							{leadPost.data.pubDate.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' })}
						</time>
					</div>
				</article>
			)}

			{visualFrontPosts.length > 0 && (
				<section class="frontline-grid" aria-label="Свежие материалы">
					{visualFrontPosts.map((post, index) => (
						<article class="frontline-card">
							<PostThumbnail post={post} className="frontline-card__media" toneClass={getToneClass(index + 1)} />
							<div class="frontline-card__body">
								<div class="frontline-card__meta">
									<span class="content-tag"><RubricLabel name={getPrimaryRubric(post)} /></span>
									<span>{getArticleTypeLabel(post)}</span>
								</div>
								<h2 class="frontline-card__title">
									<a href={getPostHref(post)}>{post.data.title}</a>
								</h2>
								{post.data.description && <p class="frontline-card__desc">{post.data.description}</p>}
								<time class="frontline-card__date">
									{post.data.pubDate.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long' })}
								</time>
							</div>
						</article>
					))}
				</section>
			)}

			{clusterPosts.length > 0 && (
				<section class="signal-board" aria-label="Редакционные сюжеты">
					<div class="section-head">
						<h2>Сюжеты</h2>
						<a href="/blog">Архив всех материалов</a>
					</div>
					<div class="signal-board__grid">
						{clusterPosts.map((cluster) => (
							<a class="signal-board__item" href={getClusterHref(cluster.slug)}>
								<span class="signal-board__kicker">Сюжет</span>
								<strong>{cluster.title}</strong>
								<p>{cluster.latest.data.description}</p>
								<span class="signal-board__meta">{cluster.count} материалов</span>
							</a>
						))}
					</div>
				</section>
			)}

			<div class="dual-stream">
				<section class="stream-col">
					<h2 class="stream-col__head">Новости</h2>
					{newsPosts.map((post) => (
						<a class="post-row" href={getPostHref(post)}>
							<time class="post-row__date">
								{post.data.pubDate.toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' })}
							</time>
							<span class="post-row__rubric"><RubricLabel name={getPrimaryRubric(post)} /></span>
							<strong class="post-row__title">{post.data.title}</strong>
						</a>
					))}
					<a class="post-stream__more" href="/blog">Все новости →</a>
				</section>

				<section class="stream-col">
					<h2 class="stream-col__head">Аналитика</h2>
					{analysisPosts.map((post) => (
						<a class="analysis-row" href={getPostHref(post)}>
							<div class="analysis-row__top">
								<span class="post-row__rubric"><RubricLabel name={getPrimaryRubric(post)} /></span>
								<time class="post-row__date">
									{post.data.pubDate.toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' })}
								</time>
							</div>
							<strong class="post-row__title">{post.data.title}</strong>
							{post.data.description && (
								<p class="analysis-row__desc">{post.data.description}</p>
							)}
						</a>
					))}
					<a class="post-stream__more" href="/blog">Вся аналитика →</a>
				</section>
			</div>

			{columnPosts.length > 0 && (
				<section class="essay-strip" aria-label="Колонки">
					<div class="section-head">
						<h2>Колонки</h2>
						<a href="/blog#columns">Все колонки</a>
					</div>
					<div class="essay-strip__grid">
						{columnPosts.map((post) => (
							<a class="essay-strip__item" href={getPostHref(post)}>
								<span class="essay-strip__meta"><RubricLabel name={getPrimaryRubric(post)} /></span>
								<strong>{post.data.title}</strong>
								<p>{post.data.description}</p>
							</a>
						))}
					</div>
				</section>
			)}

			{rubricSummary.length > 0 && (
				<nav class="rubric-nav-strip" aria-label="Рубрики">
					{rubricSummary.map((rubric) => (
						<a class="rubric-nav-tile" href={getRubricHref(rubric.slug!)}>
							<strong><RubricLabel name={rubric.name} /></strong>
							<span>{rubric.count}</span>
						</a>
					))}
				</nav>
			)}

		</main>

		<Footer />
	</body>
</html>
