---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostThumbnail from '../../components/PostThumbnail.astro';
import RubricLabel from '../../components/RubricLabel.astro';
import TickerBar from '../../components/TickerBar.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import {
	buildRubricSummary,
	getArticleTypeLabel,
	getPostHref,
	getPrimaryRubric,
	getReadingTimeLabel,
	getToneClass,
	getVisiblePosts,
	sortPosts,
} from '../../lib/site';

const posts = sortPosts(getVisiblePosts(await getCollection('posts')));
const rubricSummary = buildRubricSummary(posts).slice(0, 6);
const newsPosts = posts.filter((post) => post.data.articleType === 'news');
const analysisPosts = posts.filter((post) => post.data.articleType === 'analysis');
const columnPosts = posts.filter((post) => post.data.articleType === 'column');
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={`${SITE_TITLE} — Архив`} description={SITE_DESCRIPTION} image={posts[0]?.data.heroImage} />
	</head>
	<body>
		<Header />
		<TickerBar />
		<main class="main-shell">
			<section class="archive-hero" id="top">
				<div>
					<p class="section-kicker">Архив</p>
					<h1>Все публикации SCQR</h1>
				</div>
				<p>
					Новости, аналитика и колонки о рынке искусственного интеллекта. Каждый материал снабжён рубрикой, форматом и хронологией.
				</p>
			</section>

			<section class="archive-summary-grid">
				<div class="archive-summary-card">
					<strong>{posts.length}</strong>
					<span>материалов импортировано</span>
				</div>
				{
					rubricSummary.map((rubric) => (
						<div class="archive-summary-card">
							<strong><RubricLabel name={rubric.name} /></strong>
							<span>{rubric.count} публикаций</span>
						</div>
					))
				}
			</section>

			<nav class="archive-section-nav" aria-label="Разделы архива">
				<a href="#news">Новости</a>
				<a href="#analysis">Аналитика</a>
				<a href="#columns">Колонки</a>
			</nav>

			<section class="archive-section" id="news">
				<div class="section-head">
					<h2>Новости</h2>
					<a href="#top">Наверх · {newsPosts.length}</a>
				</div>
				<div class="archive-feed">
					{newsPosts.map((post, index) => (
						<article class="archive-feed__item">
							<PostThumbnail post={post} className="archive-feed__thumb" toneClass={getToneClass(index)} />
							<div>
								<div class="archive-feed__meta">
									<span class="content-tag"><RubricLabel name={getPrimaryRubric(post)} /></span>
									<span>{getArticleTypeLabel(post)}</span>
									<span>{getReadingTimeLabel(post)}</span>
								</div>
								<h2><a href={getPostHref(post)}>{post.data.title}</a></h2>
								<p>{post.data.description}</p>
							</div>
						</article>
					))}
				</div>
			</section>

			<section class="archive-section" id="analysis">
				<div class="section-head">
					<h2>Аналитика</h2>
					<a href="#top">Наверх · {analysisPosts.length}</a>
				</div>
				<div class="archive-feed">
					{analysisPosts.map((post, index) => (
						<article class="archive-feed__item">
							<PostThumbnail post={post} className="archive-feed__thumb" toneClass={getToneClass(index + 1)} />
							<div>
								<div class="archive-feed__meta">
									<span class="content-tag"><RubricLabel name={getPrimaryRubric(post)} /></span>
									<span>{getArticleTypeLabel(post)}</span>
									<span>{getReadingTimeLabel(post)}</span>
								</div>
								<h2><a href={getPostHref(post)}>{post.data.title}</a></h2>
								<p>{post.data.description}</p>
							</div>
						</article>
					))}
				</div>
			</section>

			<section class="archive-section" id="columns">
				<div class="section-head">
					<h2>Колонки</h2>
					<a href="#top">Наверх · {columnPosts.length}</a>
				</div>
				<div class="archive-feed">
					{columnPosts.map((post, index) => (
						<article class="archive-feed__item">
							<PostThumbnail post={post} className="archive-feed__thumb" toneClass={getToneClass(index + 2)} />
							<div>
								<div class="archive-feed__meta">
									<span class="content-tag"><RubricLabel name={getPrimaryRubric(post)} /></span>
									<span>{getArticleTypeLabel(post)}</span>
									<span>{getReadingTimeLabel(post)}</span>
								</div>
								<h2><a href={getPostHref(post)}>{post.data.title}</a></h2>
								<p>{post.data.description}</p>
							</div>
						</article>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
