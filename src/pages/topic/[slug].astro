---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import RubricLabel from '../../components/RubricLabel.astro';
import TickerBar from '../../components/TickerBar.astro';
import { SITE_TITLE } from '../../consts';
import {
	buildTopicIndex,
	getArticleTypeLabel,
	getPostHref,
	getPrimaryRubric,
	getVisiblePosts,
	sortPosts,
} from '../../lib/site';

export async function getStaticPaths() {
	const posts = sortPosts(getVisiblePosts(await getCollection('posts')));
	const index = buildTopicIndex(posts);
	return [...index.entries()].map(([slug, { label, posts: topicPosts }]) => ({
		params: { slug },
		props: { slug, label, posts: sortPosts(topicPosts) },
	}));
}

const { label, posts } = Astro.props;
const leadPost = posts[0];
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={`${label} — ${SITE_TITLE}`} description={`Материалы SCQR по теме «${label}».`} image={leadPost?.data.heroImage} />
	</head>
	<body>
		<Header />
		<TickerBar />
		<main class="main-shell">
			<section class="topic-hero">
				<p class="section-kicker">Тема</p>
				<h1 class="topic-hero__title">{label}</h1>
				<p class="topic-hero__desc">
					Подборка материалов SCQR по одной теме: короткие сигналы, более длинные разборы и
					колонки, которые помогают увидеть не одну новость, а движение всей линии.
				</p>
				<div class="topic-hero__meta">
					<span>{posts.length} материалов</span>
					<a href="/blog" class="topic-hero__back">← Архив</a>
				</div>
			</section>

			<section class="topic-list">
				{posts.map((post) => (
					<a class="topic-list__item" href={getPostHref(post)}>
						<div class="topic-list__meta">
							<span class="content-tag"><RubricLabel name={getPrimaryRubric(post)} /></span>
							<span>{getArticleTypeLabel(post)}</span>
							<span>{post.data.pubDate.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
						</div>
						<strong class="topic-list__title">{post.data.title}</strong>
						<p class="topic-list__desc">{post.data.description}</p>
					</a>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>
