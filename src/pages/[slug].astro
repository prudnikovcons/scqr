---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../layouts/BlogPost.astro';
import {
	getStrongNextPost,
	getClusterConfig,
	getClusterPosts,
	getVisiblePosts,
	sortPosts,
} from '../lib/site';

export async function getStaticPaths() {
	const posts = sortPosts(getVisiblePosts(await getCollection('posts')));
	return posts.map((post) => {
		const clusterSlug = post.data.storyCluster;
		const clusterConfig = clusterSlug ? getClusterConfig(clusterSlug) : undefined;
		const clusterSize = clusterSlug
			? getClusterPosts(posts, clusterSlug).length
			: 0;
		const nextStrong = getStrongNextPost(posts, post);
		return {
			params: { slug: post.id },
			props: {
				post,
				nextStrong,
				clusterSlug: clusterSlug ?? null,
				clusterTitle: clusterConfig?.title ?? null,
				clusterSize,
			},
		};
	});
}

type Props = {
	post: CollectionEntry<'posts'>;
	nextStrong: CollectionEntry<'posts'> | null;
	clusterSlug: string | null;
	clusterTitle: string | null;
	clusterSize: number;
};

const { post, nextStrong, clusterSlug, clusterTitle, clusterSize } = Astro.props as Props;
const { Content } = await render(post);
---

<BlogPost
	{...post.data}
	nextStrong={nextStrong}
	clusterSlug={clusterSlug}
	clusterTitle={clusterTitle}
	clusterSize={clusterSize}
>
	<Content />
</BlogPost>
