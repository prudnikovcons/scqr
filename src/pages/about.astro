---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title="About SCQR" description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="main-shell">
			<section class="content-panel prose">
				<p class="section-kicker">О проекте</p>
				<h1>SCQR — аналитическое медиа о рынке искусственного интеллекта.</h1>
				<p>
					Текущий фронтенд — это первый production-oriented слой после WordPress: статический Astro-сайт, подготовленный для Git-based deployment на Vercel.
				</p>
				<p>
					Задача проекта — не просто публиковать новости, а собирать из них связную карту рынка: инфраструктура, капитал, регулирование, внедрение и редакционные интерпретации.
				</p>
				<p>
					Операционная модель проекта описана в [docs/agent-operating-model.md](/D:/CODEX/gitscqr/scqr/docs/agent-operating-model.md), а deploy-процедура — в [docs/vercel-runbook.md](/D:/CODEX/gitscqr/scqr/docs/vercel-runbook.md).
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
