---
import { SITE_TITLE } from '../consts';

const primaryLinks = [
	{ href: '/blog', label: 'Новости' },
	{ href: '/#analysis', label: 'Аналитика' },
	{ href: '/#columns', label: 'Колонки' },
	{ href: '/#weekly-digest', label: 'Дайджест' },
	{ href: '/#registry', label: 'Реестр' },
	{ href: '/about', label: 'О проекте' },
];

const rubrics = [
	'Траектории ИИ',
	'Генерации ИИ',
	'Автоматизации ИИ',
	'Новации ИИ',
	'Иллюзии ИИ',
	'В России',
	'Регуляции ИИ',
	'Теории ИИ',
	'Тенденции ИИ',
];
---

<header class="site-header">
	<div class="site-header__main">
		<a class="site-brand" href="/">
			<span class="site-brand__mark">{SITE_TITLE}<i>.</i></span>
			<span class="site-brand__descriptor">Новости и аналитика<br />о рынке ИИ</span>
		</a>

		<nav class="site-nav" aria-label="Primary navigation">
			{
				primaryLinks.map((link) => (
					<a href={link.href}>{link.label}</a>
				))
			}
		</nav>

		<div class="site-tools">
			<a class="site-tool" href="/rss.xml" aria-label="RSS">RSS</a>
			<a class="site-tool" href="/about" aria-label="О проекте">О проекте</a>
			<a class="site-button" href="/#subscription">Подписка</a>
		</div>
	</div>

	<div class="site-header__rubrics">
		{
			rubrics.map((rubric) => (
				<a href="/#rubrics">{rubric}</a>
			))
		}
	</div>
</header>
