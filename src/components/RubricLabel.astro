---
interface Props {
	name: string;
}
const { name } = Astro.props;
const hasAIWord = /\sИИ$/u.test(name);
const base = hasAIWord ? name.slice(0, -3) : name;
---

<span class="rubric-label"><span class="rubric-label__base">{base}</span>{hasAIWord && <span class="rubric-label__ai"> ИИ</span>}</span>
