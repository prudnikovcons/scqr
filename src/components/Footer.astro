---
const year = new Date().getFullYear();

const columns = [
	{
		title: 'Разделы',
		items: [
			{ label: 'Новости', href: '/blog' },
			{ label: 'Аналитика', href: '/#analysis' },
			{ label: 'Колонки', href: '/#columns' },
			{ label: 'Дайджест', href: '/#weekly-digest' },
		],
	},
	{
		title: 'Навигация',
		items: [
			{ label: 'Главная', href: '/' },
			{ label: 'Реестр', href: '/#registry' },
			{ label: 'Архив', href: '/blog' },
			{ label: 'RSS', href: '/rss.xml' },
		],
	},
	{
		title: 'Проект',
		items: [
			{ label: 'О проекте', href: '/about' },
			{ label: 'Рубрики', href: '/#rubrics' },
		],
	},
];
---

<footer class="site-footer">
	<div class="site-footer__grid">
		<div class="site-footer__brand">
			<p class="site-footer__mark">SCQR.</p>
			<p>
				Система сигналов и контекста на рынке искусственного интеллекта: без новостного шума, с фокусом на структуру, власть и последствия.
			</p>
		</div>

		{
			columns.map((column) => (
				<div>
					<p class="site-footer__heading">{column.title}</p>
					<ul class="site-footer__list">
						{column.items.map((item) => (
							<li><a href={item.href}>{item.label}</a></li>
						))}
					</ul>
				</div>
			))
		}
	</div>

	<div class="site-footer__meta">
		<span>© {year} SCQR</span>
		<span>Signal × Context × Quality × Reach</span>
	</div>
</footer>
