---
const year = new Date().getFullYear();

const columns = [
	{
		title: 'Разделы',
		items: ['Новости', 'Аналитика', 'Колонки', 'Дайджест'],
	},
	{
		title: 'Поверхности',
		items: ['Главная', 'Реестр', 'Архив', 'RSS'],
	},
	{
		title: 'Проект',
		items: ['О проекте', 'Операционная модель', 'Vercel runbook'],
	},
];
---

<footer class="site-footer">
	<div class="site-footer__grid">
		<div class="site-footer__brand">
			<p class="site-footer__mark">SCQR.</p>
			<p>
				Система сигналов и контекста на рынке искусственного интеллекта: без новостного шума, с фокусом на структуру, власть и последствия.
			</p>
		</div>

		{
			columns.map((column) => (
				<div>
					<p class="site-footer__heading">{column.title}</p>
					<ul class="site-footer__list">
						{column.items.map((item) => <li>{item}</li>)}
					</ul>
				</div>
			))
		}
	</div>

	<div class="site-footer__meta">
		<span>© {year} SCQR</span>
		<span>Signal × Context × Quality × Reach</span>
		<span>Статический frontend для Vercel</span>
	</div>
</footer>
