---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import PostThumbnail from '../components/PostThumbnail.astro';
import RubricLabel from '../components/RubricLabel.astro';
import TickerBar from '../components/TickerBar.astro';
import {
	getArticleTypeLabel,
	getArticleTypeLabelFromValue,
	getClusterHref,
	getPostHref,
	getPrimaryRubric,
	getReadingTimeLabel,
	getToneClass,
	getTopicHref,
} from '../lib/site';

type PostEntry = CollectionEntry<'posts'>;

type Props = PostEntry['data'] & {
	related?: PostEntry[];
	prev?: PostEntry | null;
	next?: PostEntry | null;
	adjacentScope?: 'cluster' | 'rubric' | null;
	clusterSlug?: string | null;
	clusterTitle?: string | null;
	clusterSize?: number;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	articleType,
	rubrics = [],
	rubricLabels = [],
	topics = [],
	sourceNote,
	related = [],
	prev = null,
	next = null,
	adjacentScope = null,
	clusterSlug = null,
	clusterTitle = null,
	clusterSize = 0,
} = Astro.props;

const displayRubrics = rubricLabels.length > 0 ? rubricLabels : rubrics;
const scopeLabel = adjacentScope === 'cluster' ? 'В сюжете' : 'В рубрике';
const leadRubric = displayRubrics[0] ?? 'SCQR';
const readingTimeLabel = `${Astro.props.readingTime ?? 1} мин`;
const topicPreview = topics.slice(0, 8);
---

<html lang="ru">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage}
			type="article"
			publishedTime={pubDate}
			updatedTime={updatedDate}
			section={leadRubric}
		/>
	</head>

	<body>
		<Header />
		<TickerBar />
		<main class="main-shell">
			<article class="article-shell">
				<section class="article-head">
					<div class="article-head__main">
						<div class="article-meta-row">
							<div class="article-chip-row">
								{
									displayRubrics.map((rubric) => (
										<span class="article-chip"><RubricLabel name={rubric} /></span>
									))
								}
								<span class="article-chip article-chip-muted">{getArticleTypeLabelFromValue(articleType)}</span>
							</div>
							<div class="article-date-row">
								<FormattedDate date={pubDate} />
								<span>{readingTimeLabel}</span>
								{
									updatedDate && (
										<span class="article-updated">
											Обновлено <FormattedDate date={updatedDate} />
										</span>
									)
								}
							</div>
						</div>
						{clusterSlug && clusterTitle && clusterSize > 1 && (
							<a class="article-cluster-chip" href={getClusterHref(clusterSlug)}>
								<span class="article-cluster-chip__kicker">Часть сюжета</span>
								<span class="article-cluster-chip__title">{clusterTitle}</span>
								<span class="article-cluster-chip__count">{clusterSize} материалов →</span>
							</a>
						)}
						<h1 class="article-title">{title}</h1>
						<p class="article-dek">{description}</p>
					</div>

					<aside class="article-head__rail" aria-label="Контекст материала">
						<div class="article-rail-block article-rail-block--accent">
							<span class="article-rail__kicker">SCQR вывод</span>
							<p>{description}</p>
						</div>

						<div class="article-rail-block">
							<span class="article-rail__kicker">Формат</span>
							<ul class="article-rail__list">
								<li>{getArticleTypeLabelFromValue(articleType)}</li>
								<li>{readingTimeLabel}</li>
								<li><FormattedDate date={pubDate} /></li>
							</ul>
						</div>

						{sourceNote && (
							<div class="article-rail-block">
								<span class="article-rail__kicker">Основание публикации</span>
								<p>{sourceNote}</p>
							</div>
						)}

						{topicPreview.length > 0 && (
							<div class="article-rail-block">
								<span class="article-rail__kicker">Темы</span>
								<div class="article-chip-row article-chip-row--tight">
									{topicPreview.map((topic) => (
										<a href={getTopicHref(topic)} class="article-chip article-chip-muted article-chip-link">{topic}</a>
									))}
								</div>
							</div>
						)}
					</aside>
				</section>

				{heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}

				<div class="article-reading-layout">
					<div class="article-frame prose">
						<slot />
					</div>

					<aside class="article-reading-rail" aria-label="Навигация по статье">
						{clusterSlug && clusterTitle && clusterSize > 1 && (
							<div class="article-rail-block">
								<span class="article-rail__kicker">Сюжет</span>
								<a class="article-reading-rail__story" href={getClusterHref(clusterSlug)}>
									<strong>{clusterTitle}</strong>
									<span>{clusterSize} материалов в одной линии</span>
								</a>
							</div>
						)}

						{prev && (
							<div class="article-rail-block">
								<span class="article-rail__kicker">{scopeLabel}</span>
								<a class="article-reading-rail__story" href={getPostHref(prev)}>
									<strong>{prev.data.title}</strong>
									<span>Предыдущий материал</span>
								</a>
							</div>
						)}
					</aside>
				</div>

				{(prev || next) && (
					<nav class="article-adjacent" aria-label="Навигация по материалам">
						<span class="article-adjacent__scope">{scopeLabel}</span>
						<div class="article-adjacent__row">
							{prev ? (
								<a class="article-adjacent__link article-adjacent__link--prev" href={getPostHref(prev)}>
									<span class="article-adjacent__dir">← Предыдущий</span>
									<strong>{prev.data.title}</strong>
								</a>
							) : <span />}
							{next ? (
								<a class="article-adjacent__link article-adjacent__link--next" href={getPostHref(next)}>
									<span class="article-adjacent__dir">Следующий →</span>
									<strong>{next.data.title}</strong>
								</a>
							) : <span />}
						</div>
					</nav>
				)}

				{related.length > 0 && (
					<section class="article-related">
						<h2 class="article-related__head">Продолжение темы</h2>
						<div class="article-related__grid">
							{related.map((item, index) => (
								<article class="article-related__item">
									<PostThumbnail post={item} className="article-related__thumb" toneClass={getToneClass(index)} />
									<div class="article-related__body">
										<div class="archive-feed__meta">
											<span class="content-tag"><RubricLabel name={getPrimaryRubric(item)} /></span>
											<span>{getArticleTypeLabel(item)}</span>
											<span>{getReadingTimeLabel(item)}</span>
										</div>
										<h3 class="article-related__title">
											<a href={getPostHref(item)}>{item.data.title}</a>
										</h3>
										<p>{item.data.description}</p>
									</div>
								</article>
							))}
						</div>
					</section>
				)}
			</article>
		</main>
		<Footer />
	</body>
</html>
