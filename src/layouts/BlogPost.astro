---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import RubricLabel from '../components/RubricLabel.astro';
import TickerBar from '../components/TickerBar.astro';
import {
	getArticleTypeLabelFromValue,
	getClusterHref,
	getDeck,
	getPostHref,
	getTopicHref,
} from '../lib/site';
import { buildArticleJsonLd } from '../lib/structuredData';

type PostEntry = CollectionEntry<'posts'>;

type Props = PostEntry['data'] & {
	nextStrong?: PostEntry | null;
	clusterSlug?: string | null;
	clusterTitle?: string | null;
	clusterSize?: number;
};

const {
	title,
	description,
	deck,
	scqrVerdict,
	pubDate,
	updatedDate,
	heroImage,
	heroAlt,
	articleType,
	rubrics = [],
	rubricLabels = [],
	topics = [],
	sourceNote,
	nextStrong = null,
	clusterSlug = null,
	clusterTitle = null,
	clusterSize = 0,
	readingTime = 1,
} = Astro.props;

const displayRubrics = rubricLabels.length > 0 ? rubricLabels : rubrics;
const leadRubric = displayRubrics[0] ?? 'SCQR';
const topicPreview = topics.slice(0, 8);
const articleDeck = deck?.trim() || description;
const articleVerdict = scqrVerdict?.trim() || articleDeck;
const showClusterCard = Boolean(clusterSlug && clusterTitle && clusterSize > 1);
const articleJsonLd = buildArticleJsonLd({
	title,
	description: articleDeck,
	path: Astro.url.pathname,
	image: heroImage,
	publishedTime: pubDate,
	updatedTime: updatedDate,
	section: leadRubric,
});
---

<html lang="ru">
	<head>
		<BaseHead
			title={title}
			description={articleDeck}
			image={heroImage}
			imageAlt={heroAlt}
			type="article"
			publishedTime={pubDate}
			updatedTime={updatedDate}
			section={leadRubric}
			jsonLd={articleJsonLd}
		/>
	</head>

	<body>
		<Header />
		<TickerBar />
		<main class="main-shell">
			<article class="article-shell">
				<section class="article-hero">
					<div class:list={['article-hero__frame', !heroImage && 'article-hero__frame--text-only']}>
						<div class="article-hero__content">
							<div class="article-meta-row">
								<div class="article-chip-row">
									{
										displayRubrics.map((rubric) => (
											<span class="article-chip"><RubricLabel name={rubric} /></span>
										))
									}
									<span class="article-chip article-chip-muted">{getArticleTypeLabelFromValue(articleType)}</span>
									<span class="article-chip article-chip-muted">{readingTime} мин</span>
								</div>
								<div class="article-date-row">
									<FormattedDate date={pubDate} />
									{
										updatedDate && (
											<span class="article-updated">
												Обновлено <FormattedDate date={updatedDate} />
											</span>
										)
									}
								</div>
							</div>
							<h1 class="article-title">{title}</h1>
							<p class="article-dek">{articleDeck}</p>
						</div>
						{
							heroImage && (
								<div class="article-hero__media">
									<Image width={1440} height={960} src={heroImage} alt={heroAlt} />
								</div>
							)
						}
					</div>
				</section>

				<section class="article-verdict">
					<span class="article-verdict__kicker">SCQR вывод</span>
					<p>{articleVerdict}</p>
				</section>

				<div class="article-reading-layout">
					<div class="article-frame prose">
						<slot />
					</div>

					<aside class="article-reading-rail" aria-label="Контекст материала">
						<div class="article-rail-block">
							<span class="article-rail__kicker">Формат</span>
							<ul class="article-rail__list">
								<li>{getArticleTypeLabelFromValue(articleType)}</li>
								<li>{readingTime} мин</li>
								<li><FormattedDate date={pubDate} /></li>
							</ul>
						</div>

						{sourceNote && (
							<div class="article-rail-block">
								<span class="article-rail__kicker">Основание публикации</span>
								<p>{sourceNote}</p>
							</div>
						)}

						{showClusterCard && (
							<div class="article-rail-block">
								<span class="article-rail__kicker">Сюжет</span>
								<a class="article-reading-rail__story" href={getClusterHref(clusterSlug!)}>
									<strong>{clusterTitle}</strong>
									<span>{clusterSize} материалов в одной линии</span>
								</a>
							</div>
						)}

						{topicPreview.length > 0 && (
							<div class="article-rail-block">
								<span class="article-rail__kicker">Темы</span>
								<div class="article-chip-row article-chip-row--tight">
									{topicPreview.map((topic) => (
										<a href={getTopicHref(topic)} class="article-chip article-chip-muted article-chip-link">{topic}</a>
									))}
								</div>
							</div>
						)}

						{nextStrong && (
							<div class="article-rail-block">
								<span class="article-rail__kicker">Следующий сильный материал</span>
								<a class="article-reading-rail__story" href={getPostHref(nextStrong)}>
									<strong>{nextStrong.data.title}</strong>
									<span>{getDeck(nextStrong)}</span>
								</a>
							</div>
						)}
					</aside>
				</div>

				<section class="article-exit-grid" aria-label="Следующие переходы">
					{showClusterCard && (
						<a class="article-exit-card" href={getClusterHref(clusterSlug!)}>
							<span class="article-exit-card__kicker">По этому сюжету</span>
							<strong>{clusterTitle}</strong>
							<p>{clusterSize} материалов в одной редакционной линии.</p>
						</a>
					)}

					{nextStrong && (
						<a class="article-exit-card article-exit-card--story" href={getPostHref(nextStrong)}>
							<span class="article-exit-card__kicker">Следующий сильный материал</span>
							<strong>{nextStrong.data.title}</strong>
							<p>{getDeck(nextStrong)}</p>
						</a>
					)}
				</section>
			</article>
		</main>
		<Footer />
	</body>
</html>
