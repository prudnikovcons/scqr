---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { getDeck, getHeroAlt, getPostHref } from '../lib/site';
import FormattedDate from './FormattedDate.astro';

type PostEntry = CollectionEntry<'posts'>;

interface Props {
	lead: PostEntry;
	subgrid: PostEntry[];
}

const { lead, subgrid } = Astro.props;
const leadHref = getPostHref(lead);
const leadDeck = getDeck(lead);

const subgridItems = subgrid.slice(0, 4).map((post) => ({
	post,
	href: getPostHref(post),
	title: post.data.title,
	heroImage: post.data.heroImage,
	heroAlt: getHeroAlt(post),
}));
---

<article class="hero-feature">
	<div>
		<h1>
			<a href={leadHref} class="hero-feature-link">{lead.data.title}</a>
		</h1>
		<p>{leadDeck}</p>
		<div class="meta">
			<FormattedDate date={lead.data.pubDate} />
			<span class="dot"></span>
			{
				lead.data.readingTime && (
					<span>
						{lead.data.readingTime} мин чтения
					</span>
				)
			}
		</div>
	</div>
	<div class="hero-mascot">
		<img src="/mascot/hero.png" alt="" width="320" height="320" loading="eager" />
	</div>
</article>

<div class="hero-sub-grid">
	{
		subgridItems.map((item) => (
			<a class="sub-card" href={item.href}>
				<div class="thumb">
					{item.heroImage ? (
						<Image
							src={item.heroImage}
							alt={item.heroAlt}
							loading="lazy"
							widths={[320, 480]}
							sizes="(max-width: 720px) 50vw, 25vw"
						/>
					) : (
						<span class="thumb-fallback">{(item.title || '?').charAt(0).toUpperCase()}</span>
					)}
				</div>
				<h4>{item.title}</h4>
			</a>
		))
	}
</div>

<style>
	.hero-feature-link {
		color: inherit;
		text-decoration: none;
	}
	.hero-feature-link:hover {
		color: var(--violet-700);
	}
	.hero-mascot {
		align-self: end;
		display: flex;
		justify-content: center;
	}
	.hero-mascot img {
		width: 100%;
		max-width: 280px;
		height: auto;
	}
	.sub-card {
		text-decoration: none;
		color: inherit;
	}
	.sub-card .thumb {
		position: relative;
		aspect-ratio: 16 / 10;
		border-radius: 10px;
		overflow: hidden;
		background: var(--paper-2);
		margin-bottom: 8px;
	}
	.sub-card .thumb :global(img) {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.thumb-fallback {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		height: 100%;
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 48px;
		color: var(--violet-300, #c8b8ff);
		background: linear-gradient(135deg, var(--paper-2), var(--violet-50, #f5f0ff));
	}
</style>
