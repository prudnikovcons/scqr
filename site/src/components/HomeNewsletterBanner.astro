---
const features = [
	'Только проверенные новости',
	'Экспертные мнения и аналитика',
	'Удобно, быстро и без воды',
];
---

<section class="newsletter" id="subscribe">
	<div class="mascot">
		<img src="/editorial/2026-refresh/mascot/mascot_laptop_transparent.webp" alt="" loading="lazy" />
	</div>
	<div>
		<div class="pitch">
			Читай <span class="ru">SCQR.RU</span> в Telegram
		</div>
		<div class="feats">
			{
				features.map((feature) => (
					<span class="feat">
						<span class="dot" />
						{feature}
					</span>
				))
			}
		</div>
	</div>
	<a href="https://t.me/scqr_ai" class="cta" target="_blank" rel="noopener">Подписаться на канал</a>
</section>

<style>
	.newsletter .cta {
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}
</style>
