---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import {
	getArticleTypeLabel,
	getDeck,
	getHeroAlt,
	getPostHref,
	getPrimaryRubric,
	getReadingTimeLabel,
	RUBRIC_CONFIG,
} from '../lib/site';

type PostEntry = CollectionEntry<'posts'>;

interface Props {
	post: PostEntry;
}

const { post } = Astro.props;
const href = getPostHref(post);
const rubricSlug = getPrimaryRubric(post);
const rubricLabel =
	RUBRIC_CONFIG.find((r) => r.slug === rubricSlug)?.label ?? rubricSlug;
const dateLabel = post.data.pubDate.toLocaleDateString('ru-RU', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
});
---

<a class="archive-row" href={href}>
	<div class="archive-row__thumb">
		{
			post.data.heroImage ? (
				<Image src={post.data.heroImage} alt={getHeroAlt(post)} width={240} height={240} loading="lazy" />
			) : (
				<div class="archive-row__thumb-placeholder">{post.data.title.charAt(0).toUpperCase()}</div>
			)
		}
	</div>
	<div class="archive-row__body">
		<div class="archive-row__meta">
			<span class="archive-row__pill archive-row__pill--rubric">{rubricLabel}</span>
			<span class="archive-row__pill archive-row__pill--type">{getArticleTypeLabel(post)}</span>
			<span class="archive-row__time">{getReadingTimeLabel(post)}</span>
			<span class="archive-row__divider"></span>
			<span class="archive-row__date">{dateLabel}</span>
		</div>
		<h3 class="archive-row__title">{post.data.title}</h3>
		<p class="archive-row__deck">{getDeck(post)}</p>
		{
			post.data.topics.length > 0 && (
				<div class="archive-row__topics">
					{post.data.topics.slice(0, 4).map((topic) => (
						<span class="archive-row__topic">{topic}</span>
					))}
				</div>
			)
		}
	</div>
</a>

<style>
	.archive-row {
		display: grid;
		grid-template-columns: 120px 1fr;
		gap: 20px;
		padding: 20px 12px;
		border-bottom: 1px solid var(--line);
		text-decoration: none;
		color: inherit;
		position: relative;
		transition: background 120ms;
	}
	.archive-row:hover {
		background: var(--paper-2);
	}
	.archive-row::before {
		content: '';
		position: absolute;
		left: 0;
		top: 16px;
		bottom: 16px;
		width: 3px;
		border-radius: 2px;
		background: transparent;
		transition: background 120ms;
	}
	.archive-row:hover::before {
		background: var(--violet-500);
	}
	.archive-row__thumb {
		width: 120px;
		height: 120px;
		border-radius: 8px;
		overflow: hidden;
		background: var(--paper-3);
		border: 1px solid var(--line);
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.archive-row__thumb :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.archive-row__thumb-placeholder {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 36px;
		color: var(--ink-700);
	}
	.archive-row__body {
		min-width: 0;
	}
	.archive-row__meta {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		align-items: center;
		margin-bottom: 8px;
	}
	.archive-row__pill {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 11px;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		padding: 3px 9px;
		border-radius: 999px;
	}
	.archive-row__pill--rubric {
		background: var(--violet-50);
		color: var(--violet-600);
		border: 1px solid var(--violet-100);
	}
	.archive-row__pill--type {
		background: #fff;
		color: var(--ink-700);
		border: 1px solid var(--line);
	}
	.archive-row__time {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--ink-500);
		font-weight: 500;
	}
	.archive-row__divider {
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--ink-300);
	}
	.archive-row__date {
		font-family: var(--font-body);
		font-size: 12px;
		color: var(--ink-500);
	}
	.archive-row__title {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 19px;
		line-height: 1.3;
		letter-spacing: -0.015em;
		color: var(--ink-900);
		margin: 0 0 8px;
		text-wrap: balance;
	}
	.archive-row:hover .archive-row__title {
		color: var(--violet-700);
	}
	.archive-row__deck {
		font-family: var(--font-body);
		font-size: 14px;
		line-height: 1.55;
		color: var(--ink-700);
		margin: 0 0 10px;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		text-wrap: pretty;
	}
	.archive-row__topics {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}
	.archive-row__topic {
		font-family: var(--font-body);
		font-size: 11px;
		color: var(--ink-500);
		background: var(--paper-3);
		padding: 3px 8px;
		border-radius: 999px;
		border: 1px solid var(--line);
	}

	@media (max-width: 720px) {
		.archive-row {
			grid-template-columns: 80px 1fr;
			gap: 14px;
			padding: 16px 8px;
		}
		.archive-row__thumb {
			width: 80px;
			height: 80px;
		}
		.archive-row__title {
			font-size: 16px;
		}
		.archive-row__deck {
			font-size: 13px;
		}
	}
</style>
