---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

const columns = [
	{
		title: 'Разделы',
		items: [
			{ label: 'Архив', href: '/blog/' },
			{ label: 'Дайджест', href: '/digest/' },
			{ label: 'Подборка', href: '/curated/' },
			{ label: 'Словарь', href: '/glossary/' },
		],
	},
	{
		title: 'О сайте',
		items: [
			{ label: 'О проекте', href: '/about/' },
			{ label: 'Команда', href: '/about/' },
			{ label: 'Контакты', href: '/about/' },
			{ label: 'Реклама', href: '/about/' },
		],
	},
	{
		title: 'Помощь',
		items: [
			{ label: 'Telegram-канал', href: 'https://t.me/scqr_ai', external: true },
			{ label: 'RSS', href: '/rss.xml' },
			{ label: 'Правила сайта', href: '/about/' },
			{ label: 'Политика конфиденциальности', href: '/about/' },
		],
	},
];
---

<footer class="footer">
	<div class="container">
		<div class="footer-grid">
			<div class="footer-brand">
				<a class="logo" href="/">SCQ<span class="ru">R.RU</span></a>
				<p>Самые актуальные новости мира искусственного интеллекта</p>
				<div class="socials">
					<a href="https://t.me/scqr_ai" aria-label="Telegram" target="_blank" rel="noopener">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M9.04 15.4 8.7 20.1c.5 0 .7-.2 1-.5l2.4-2.3 5 3.6c.9.5 1.6.2 1.8-.8l3.3-15.5c.3-1.3-.5-1.8-1.4-1.5L1.6 9.5c-1.3.5-1.3 1.2-.2 1.5l5.1 1.6 11.8-7.4c.6-.4 1.1-.2.7.2"/></svg>
					</a>
					<a href="https://vk.com/scqr" aria-label="VK" target="_blank" rel="noopener">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M2 6h2c0 4 3 7 5 7V6h2v3.5C13 8 14.5 6 16 6h2c-1 2-2 3-3 4 1 1 3 3 4 5h-2.5c-.5-1-2-3-3-4-.5 0-1 0-1 1V15h-2c-3 0-7-3-8-9z"/></svg>
					</a>
					<a href="https://x.com/scqr" aria-label="X / Twitter" target="_blank" rel="noopener">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18 4h3l-7 8 8 10h-6l-5-6-5 6H3l8-9-8-9h6l4 5z"/></svg>
					</a>
					<a href="/rss.xml" aria-label="RSS">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M5 19a2 2 0 1 0 4 0 2 2 0 0 0-4 0zM3 11v3c4 0 7 3 7 7h3c0-5.5-4.5-10-10-10zM3 4v3c8 0 14 6 14 14h3C20 11.5 12.5 4 3 4z"/></svg>
					</a>
				</div>
			</div>
			{
				columns.map((column) => (
					<div class="footer-col">
						<h5>{column.title}</h5>
						<ul>
							{column.items.map((item) => (
								<li>
									{item.external ? (
										<a href={item.href} target="_blank" rel="noopener">
											{item.label}
										</a>
									) : (
										<a href={item.href}>{item.label}</a>
									)}
								</li>
							))}
						</ul>
					</div>
				))
			}
			<div class="footer-mascot">
				<div class="text">Увидимся<br />в будущем!</div>
				<img src="/mascot/footer-wave.png" alt="Маскот SCQR машет рукой на прощание" width="72" height="72" loading="lazy" />
			</div>
		</div>
	</div>
</footer>

<Analytics />
<SpeedInsights />

<style>
	.footer {
		margin-top: 64px;
		border-top: 1px solid var(--line);
		padding: 32px 0 40px;
	}
	.footer-grid {
		display: grid;
		grid-template-columns: 1.4fr 1fr 1fr 1fr 1.4fr;
		gap: 32px;
		align-items: start;
	}
	.footer-brand .logo {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 22px;
		letter-spacing: -0.025em;
		color: var(--ink-900);
		text-decoration: none;
	}
	.footer-brand .logo .ru {
		color: var(--violet-500);
	}
	.footer-brand p {
		font-family: var(--font-body);
		font-size: 12px;
		color: var(--ink-500);
		margin: 12px 0 16px;
		line-height: 1.5;
		max-width: 220px;
	}
	.footer-brand .socials {
		display: flex;
		gap: 8px;
	}
	.footer-brand .socials a {
		width: 32px;
		height: 32px;
		border-radius: 50%;
		border: 1px solid var(--line);
		background: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--ink-700);
		text-decoration: none;
		transition: color 120ms, border-color 120ms;
	}
	.footer-brand .socials a:hover {
		color: var(--violet-600);
		border-color: var(--line-strong);
	}
	.footer-col h5 {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 13px;
		color: var(--ink-900);
		margin: 0 0 12px;
	}
	.footer-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 8px;
	}
	.footer-col ul a {
		font-family: var(--font-body);
		font-size: 13px;
		color: var(--ink-700);
		text-decoration: none;
	}
	.footer-col ul a:hover {
		color: var(--violet-600);
	}
	.footer-mascot {
		background: var(--violet-50);
		border: 1px solid var(--violet-100);
		border-radius: 12px;
		padding: 12px 14px;
		display: flex;
		align-items: center;
		gap: 12px;
	}
	.footer-mascot .text {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 13px;
		color: var(--ink-900);
		line-height: 1.3;
	}
	.footer-mascot img {
		width: 72px;
		height: auto;
	}

	@media (max-width: 960px) {
		.footer-grid {
			grid-template-columns: repeat(2, 1fr);
		}
		.footer-mascot {
			grid-column: 1 / -1;
		}
	}
	@media (max-width: 560px) {
		.footer-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
