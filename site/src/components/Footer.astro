---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

const year = new Date().getFullYear();

const columns = [
	{
		title: 'Разделы',
		items: [
			{ label: 'Новости', href: '/blog#news' },
			{ label: 'Аналитика', href: '/blog#analysis' },
			{ label: 'Колонки', href: '/blog#columns' },
			{ label: 'О проекте', href: '/about' },
		],
	},
	{
		title: 'Навигация',
		items: [
			{ label: 'Главная', href: '/' },
			{ label: 'Архив', href: '/blog' },
			{ label: 'RSS', href: '/rss.xml' },
			{ label: 'Рубрика “Тенденции”', href: '/rubric/tendencies/' },
		],
	},
	{
		title: 'Поверхности',
		items: [
			{ label: 'Новации', href: '/rubric/innovations/' },
			{ label: 'Генерации', href: '/rubric/generations/' },
			{ label: 'Автоматизации', href: '/rubric/automations/' },
			{ label: 'Регуляции', href: '/rubric/regulations/' },
		],
	},
];
---

<footer class="site-footer">
	<div class="site-footer__grid">
		<div class="site-footer__brand">
			<p class="site-footer__mark">SCQR.</p>
			<p>
				Система сигналов и контекста на рынке искусственного интеллекта: без новостного шума, с фокусом на структуру, власть и последствия.
			</p>
		</div>

		{
			columns.map((column) => (
				<div>
					<p class="site-footer__heading">{column.title}</p>
					<ul class="site-footer__list">
						{column.items.map((item) => (
							<li><a href={item.href}>{item.label}</a></li>
						))}
					</ul>
				</div>
			))
		}
	</div>

	<div class="site-footer__meta">
		<span>© {year} SCQR</span>
		<span>Signal × Context × Quality × Reach</span>
	</div>

	<Analytics />
	<SpeedInsights />
</footer>
