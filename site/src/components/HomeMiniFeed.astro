---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { getHeroAlt, getPostHref, getPrimaryRubric, RUBRIC_CONFIG } from '../lib/site';

const rubricLabelLookup = new Map(RUBRIC_CONFIG.map((r) => [r.slug, r.label]));

type PostEntry = CollectionEntry<'posts'>;

interface Props {
	items: PostEntry[];
}

const { items } = Astro.props;

function formatTimestamp(date: Date): string {
	const now = new Date();
	const sameDay =
		date.getFullYear() === now.getFullYear() &&
		date.getMonth() === now.getMonth() &&
		date.getDate() === now.getDate();
	const yesterday = new Date(now);
	yesterday.setDate(now.getDate() - 1);
	const isYesterday =
		date.getFullYear() === yesterday.getFullYear() &&
		date.getMonth() === yesterday.getMonth() &&
		date.getDate() === yesterday.getDate();
	const hh = String(date.getHours()).padStart(2, '0');
	const mm = String(date.getMinutes()).padStart(2, '0');
	if (sameDay) return `${hh}:${mm}`;
	if (isYesterday) return `Вчера, ${hh}:${mm}`;
	return date.toLocaleDateString('ru-RU', { day: '2-digit', month: '2-digit' });
}

const feedItems = items.slice(0, 5).map((post) => {
	const rubricSlug = getPrimaryRubric(post);
	const rubricLabel = rubricLabelLookup.get(rubricSlug) ?? 'НОВОСТИ';
	return {
		href: getPostHref(post),
		ts: formatTimestamp(post.data.pubDate),
		rubricLabel: rubricLabel.toUpperCase(),
		title: post.data.title,
		heroImage: post.data.heroImage,
		heroAlt: getHeroAlt(post),
		mark: (post.data.title || '?').charAt(0).toUpperCase(),
	};
});
---

<aside class="feed">
	<div class="feed-hdr">
		<h4>Лента новостей</h4>
		<a href="/blog/">Все новости →</a>
	</div>
	{
		feedItems.map((item) => (
			<a class="feed-item" href={item.href}>
				<div>
					<span class="ts">{item.ts}</span>
					<span class="eb">/ {item.rubricLabel}</span>
					<div class="title">{item.title}</div>
				</div>
				<div class="thumb">
					{item.heroImage ? (
						<Image
							src={item.heroImage}
							alt={item.heroAlt}
							loading="lazy"
							widths={[80, 120, 160]}
							sizes="80px"
						/>
					) : (
						<span class="thumb-fallback">{item.mark}</span>
					)}
				</div>
			</a>
		))
	}
	<a class="feed-more" href="/blog/">Больше новостей</a>
</aside>

<style>
	.feed-item,
	.feed-more {
		text-decoration: none;
		color: inherit;
	}
	.feed-item .thumb {
		position: relative;
		width: 56px;
		height: 56px;
		border-radius: 8px;
		overflow: hidden;
		background: var(--paper-2);
		flex-shrink: 0;
	}
	.feed-item .thumb :global(img) {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.feed-item .thumb-fallback {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		height: 100%;
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 18px;
		color: var(--violet-500);
		background: linear-gradient(135deg, var(--paper-2), var(--violet-50, #f5f0ff));
	}
</style>
