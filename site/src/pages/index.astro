---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import HomeEventsCard from '../components/HomeEventsCard.astro';
import HomeHero from '../components/HomeHero.astro';
import HomeMiniFeed from '../components/HomeMiniFeed.astro';
import HomeNewsletterBanner from '../components/HomeNewsletterBanner.astro';
import HomePodcastCard from '../components/HomePodcastCard.astro';
import HomePopularSection from '../components/HomePopularSection.astro';
import HomeRubricsGrid from '../components/HomeRubricsGrid.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getVisiblePosts, sortPosts } from '../lib/site';
import { buildCollectionPageJsonLd, buildWebsiteJsonLd } from '../lib/structuredData';

const posts = sortPosts(getVisiblePosts(await getCollection('posts')));
const lead = posts[0];
const subgrid = posts.slice(1, 5);
const miniFeed = posts.slice(5, 10);
const popularPool = posts.slice(10);
const popularFeature =
	popularPool.find((p) => p.data.articleType === 'analysis') ?? popularPool[0];
const popularRows = popularPool
	.filter((p) => p.id !== popularFeature?.id)
	.slice(0, 3);

const jsonLd = [
	buildWebsiteJsonLd({ title: SITE_TITLE, description: SITE_DESCRIPTION }),
	buildCollectionPageJsonLd({
		title: SITE_TITLE,
		description: SITE_DESCRIPTION,
		posts: posts.slice(0, 12),
	}),
];
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} jsonLd={jsonLd} />
	</head>
	<body>
		<Header />
		<main class="container">
			<div class="hero-grid">
				<div>
					<HomeHero lead={lead} subgrid={subgrid} />
				</div>
				<HomeMiniFeed items={miniFeed} />
			</div>
			<HomeNewsletterBanner />
			<section class="section">
				<div class="section-grid">
					<div>
						<div class="section-hdr">
							<h2>
								<span class="icon">
									<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
										<path d="M13 2 3 14h7v8l10-12h-7z"></path>
									</svg>
								</span>
								Популярное
							</h2>
						</div>
						{popularFeature && <HomePopularSection feature={popularFeature} rows={popularRows} />}
					</div>
					<div>
						<div class="section-hdr"><h2 style="font-size:18px">&nbsp;</h2></div>
						<HomeEventsCard />
					</div>
				</div>
			</section>
			<section class="section">
				<div class="section-grid">
					<div>
						<div class="section-hdr">
							<h2>Рубрики</h2>
							<a href="/blog/">Все рубрики →</a>
						</div>
						<HomeRubricsGrid />
					</div>
					<div>
						<div class="section-hdr"><h2 style="font-size:18px">&nbsp;</h2></div>
						<HomePodcastCard />
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
