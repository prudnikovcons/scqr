---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import HomeHero from '../components/HomeHero.astro';
import HomeMiniFeed from '../components/HomeMiniFeed.astro';
import HomeNewsletterBanner from '../components/HomeNewsletterBanner.astro';
import HomeRubricsGrid from '../components/HomeRubricsGrid.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { buildClusterSummary, getVisiblePosts, sortPosts } from '../lib/site';
import { buildCollectionPageJsonLd, buildWebsiteJsonLd } from '../lib/structuredData';

const posts = sortPosts(getVisiblePosts(await getCollection('posts')));
const lead = posts[0];
const subgrid = posts.slice(1, 5);
const miniFeed = posts.slice(5, 10);
const clusters = buildClusterSummary(posts).slice(0, 4);

const jsonLd = [
	buildWebsiteJsonLd({ title: SITE_TITLE, description: SITE_DESCRIPTION }),
	buildCollectionPageJsonLd({
		title: SITE_TITLE,
		description: SITE_DESCRIPTION,
		posts: posts.slice(0, 12),
	}),
];
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} jsonLd={jsonLd} />
	</head>
	<body>
		<Header />
		<main class="container">
			<div class="hero-grid">
				<div>
					<HomeHero lead={lead} subgrid={subgrid} />
				</div>
				<HomeMiniFeed items={miniFeed} />
			</div>
			<HomeNewsletterBanner />
			<section class="section">
				<div class="section-hdr">
					<h2>Рубрики</h2>
					<a href="/about/">Зачем каждая рубрика →</a>
				</div>
				<HomeRubricsGrid />
			</section>
			{
				clusters.length > 0 && (
					<section class="section">
						<div class="section-hdr">
							<h2>Сюжетные линии</h2>
							<a href="/blog/">Архив →</a>
						</div>
						<div class="home-clusters">
							{clusters.map((cluster) => (
								<a class="home-cluster" href={`/cluster/${cluster.slug}/`}>
									<div class="home-cluster__title">{cluster.title}</div>
									<div class="home-cluster__count">{cluster.count} материалов</div>
								</a>
							))}
						</div>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	.home-clusters {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 12px;
	}
	.home-cluster {
		text-decoration: none;
		color: inherit;
		display: block;
		padding: 18px 20px;
		background: #fff;
		border: 1px solid var(--line);
		border-radius: 12px;
		transition: border-color 120ms, box-shadow 120ms;
	}
	.home-cluster:hover {
		border-color: var(--line-strong);
		box-shadow: var(--shadow-1);
	}
	.home-cluster__title {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 15px;
		color: var(--ink-900);
		line-height: 1.35;
		margin-bottom: 6px;
	}
	.home-cluster__count {
		font-family: var(--font-body);
		font-size: 12px;
		color: var(--ink-500);
	}
</style>
