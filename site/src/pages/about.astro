---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import HomeNewsletterBanner from '../components/HomeNewsletterBanner.astro';
import { SITE_DESCRIPTION } from '../consts';
import { buildOrganizationJsonLd, buildWebsiteJsonLd } from '../lib/structuredData';

const aboutJsonLd = [
	buildWebsiteJsonLd({
		title: 'О проекте — SCQR',
		description: SITE_DESCRIPTION,
		path: '/about/',
	}),
	buildOrganizationJsonLd(),
];

// Mission rubrics in the order the editor cares about, with the reason
// each one belongs in the publication.
const rubricReasons = [
	{ slug: 'theories', label: 'Теории', reason: 'чтобы знать о будущем' },
	{ slug: 'automations', label: 'Автоматизации', reason: 'потому что весь мир скоро ими покроется' },
	{ slug: 'generations', label: 'Генерации', reason: 'потому что это самое понятное, что есть в ИИ сейчас' },
	{ slug: 'trajectories', label: 'Траектории', reason: 'потому что слишком многое влияет на мир ИИ — и наоборот' },
	{ slug: 'tendencies', label: 'Тенденции', reason: 'потому что у нас есть свой взгляд' },
	{ slug: 'russia', label: 'В России', reason: 'потому что следим за своей страной' },
	{ slug: 'regulations', label: 'Регуляции', reason: 'потому что они определяют, что будет с ИИ' },
	{ slug: 'innovations', label: 'Новации', reason: 'потому что в ИИ запуски и модели появляются быстрее, чем мы успеваем привыкнуть к прошлым' },
	{ slug: 'illusions', label: 'Иллюзии', reason: 'потому что хайп часто заслоняет то, что действительно меняет рынок' },
];
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title="О проекте — SCQR" description={SITE_DESCRIPTION} jsonLd={aboutJsonLd} />
	</head>
	<body>
		<Header />
		<main class="about-page container">
			<section class="about-hero">
				<span class="about-hero__pill">О ПРОЕКТЕ</span>
				<h1>Узнавать новый мир, не теряясь в потоке</h1>
				<p class="about-lede">
					Мир меняется, и искусственный интеллект скоро будет везде — заменит, перенастроит,
					ускорит. Скорость, с которой появляется новое, такова, что поспевать стало сложно
					даже специалистам.
				</p>
				<p class="about-lede">
					Задача SCQR — собрать такой информационный поток, чтобы читатель не растворялся
					в шуме новостей, а ощущал узнавание нового мира. Видел, что именно меняется в
					структуре отрасли, и сохранял связь с тем, куда она движется.
				</p>
				<p class="about-lede about-lede--center">
					Поэтому у нас есть разные разделы — каждый со своей причиной существовать.
				</p>
			</section>

			<section class="about-rubrics">
				<header class="about-rubrics__head">
					<h2>Зачем нам каждая рубрика</h2>
				</header>
				<div class="about-rubrics__grid">
					{
						rubricReasons.map((rubric) => (
							<a class="about-rubric" href={`/rubric/${rubric.slug}/`}>
								<strong>{rubric.label}</strong>
								<span>{rubric.reason}</span>
							</a>
						))
					}
				</div>
			</section>

			<section class="about-contact">
				<h2>Связаться с редакцией</h2>
				<p>
					По вопросам сотрудничества и редакционным предложениям —{' '}
					<a href="mailto:hi@scqr.ru">hi@scqr.ru</a>. По текущим публикациям — наш канал в
					Telegram:{' '}
					<a href="https://t.me/scqr_ai" target="_blank" rel="noopener">@scqr_ai</a>.
				</p>
			</section>

			<HomeNewsletterBanner />
		</main>
		<Footer />
	</body>
</html>

<style>
	.about-page {
		padding-top: 32px;
		padding-bottom: 64px;
	}
	.about-hero {
		max-width: 760px;
		margin: 0 auto 56px;
		text-align: center;
	}
	.about-hero__pill {
		display: inline-block;
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 11px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		padding: 5px 12px;
		border-radius: 999px;
		background: var(--violet-500);
		color: #fff;
		margin-bottom: 16px;
	}
	.about-hero h1 {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 40px;
		line-height: 1.15;
		letter-spacing: -0.025em;
		color: var(--ink-900);
		margin: 0 0 20px;
	}
	.about-lede {
		font-family: var(--font-body);
		font-size: 17px;
		line-height: 1.6;
		color: var(--ink-700);
		margin: 0 0 14px;
		text-align: left;
	}
	.about-lede--center {
		text-align: center;
		color: var(--ink-900);
		font-weight: 500;
		margin-top: 8px;
	}

	.about-rubrics {
		max-width: 1100px;
		margin: 0 auto 56px;
	}
	.about-rubrics__head {
		border-bottom: 2px solid var(--ink-900);
		padding-bottom: 12px;
		margin-bottom: 16px;
	}
	.about-rubrics__head h2 {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 22px;
		margin: 0;
		color: var(--ink-900);
	}
	.about-rubrics__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 12px;
	}
	.about-rubric {
		background: #fff;
		border: 1px solid var(--line);
		border-radius: 12px;
		padding: 16px 18px;
		text-decoration: none;
		color: inherit;
		transition: border-color 120ms, box-shadow 120ms;
	}
	.about-rubric:hover {
		border-color: var(--line-strong);
		box-shadow: var(--shadow-1);
	}
	.about-rubric strong {
		display: block;
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 16px;
		color: var(--ink-900);
		margin-bottom: 6px;
	}
	.about-rubric span {
		font-family: var(--font-body);
		font-size: 13px;
		line-height: 1.5;
		color: var(--ink-500);
	}

	.about-contact {
		max-width: 880px;
		margin: 0 auto 48px;
		text-align: center;
	}
	.about-contact h2 {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 22px;
		margin: 0 0 12px;
		color: var(--ink-900);
	}
	.about-contact p {
		font-family: var(--font-body);
		font-size: 15px;
		line-height: 1.6;
		color: var(--ink-700);
	}
	.about-contact a {
		color: var(--violet-600);
	}

	@media (max-width: 720px) {
		.about-hero h1 {
			font-size: 28px;
		}
		.about-rubrics__grid {
			grid-template-columns: 1fr;
		}
		.about-lede,
		.about-lede--center {
			text-align: left;
		}
	}
</style>
