---
import { getCollection } from 'astro:content';
import ArchiveRow from '../../components/ArchiveRow.astro';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import {
	buildRubricSummary,
	getDisplayRubrics,
	getHeroAlt,
	getVisiblePosts,
	sortPosts,
} from '../../lib/site';
import { buildCollectionPageJsonLd } from '../../lib/structuredData';

const posts = sortPosts(getVisiblePosts(await getCollection('posts')));
const rubricSummary = buildRubricSummary(posts).filter((rubric) => rubric.slug);
const newsPosts = posts.filter((post) => post.data.articleType === 'news');
const analysisPosts = posts.filter((post) => post.data.articleType === 'analysis');
const columnPosts = posts.filter((post) => post.data.articleType === 'column');

const rubricSections = rubricSummary.map((rubric) => ({
	id: `rubric-${rubric.slug}`,
	label: rubric.name,
	count: rubric.count,
	slug: rubric.slug,
	posts: posts.filter((post) => getDisplayRubrics(post).includes(rubric.name)),
}));

type TabKind = 'type' | 'rubric';
interface Tab {
	id: string;
	label: string;
	count: number;
	kind: TabKind;
}

const tabs: Tab[] = [
	{ id: 'news', label: 'Новости', count: newsPosts.length, kind: 'type' },
	{ id: 'analysis', label: 'Аналитика', count: analysisPosts.length, kind: 'type' },
	{ id: 'columns', label: 'Колонки', count: columnPosts.length, kind: 'type' },
	...rubricSections.map(
		(section): Tab => ({
			id: section.id,
			label: section.label,
			count: section.count,
			kind: 'rubric',
		}),
	),
];

const archiveJsonLd = buildCollectionPageJsonLd({
	title: `${SITE_TITLE} — Архив`,
	description: SITE_DESCRIPTION,
	path: '/blog/',
	image: posts[0]?.data.heroImage,
});
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead
			title={`${SITE_TITLE} — Архив`}
			description={SITE_DESCRIPTION}
			image={posts[0]?.data.heroImage}
			imageAlt={posts[0] ? getHeroAlt(posts[0]) : `${SITE_TITLE} — Архив`}
			jsonLd={archiveJsonLd}
		/>
	</head>
	<body>
		<Header />
		<main class="archive-page container" id="top">
			<section class="archive-intro">
				<span class="archive-intro__pill">АРХИВ</span>
				<h1>Все материалы SCQR</h1>
				<p>
					Новости, аналитика и колонки о рынке искусственного интеллекта. Переключайтесь
					между форматами и рубриками — материалы остаются на одной странице.
				</p>
			</section>

			<div class="archive-tabs" role="tablist" aria-label="Фильтры архива">
				{
					tabs.map((tab, index) => (
						<>
							{index === 3 && <span class="archive-tabs__divider" aria-hidden="true" />}
							<button
								type="button"
								class={`archive-tab archive-tab--${tab.kind}`}
								data-tab={tab.id}
								role="tab"
								aria-selected={tab.id === 'news' ? 'true' : 'false'}
								aria-controls={`section-${tab.id}`}
							>
								<span class="archive-tab__label">{tab.label}</span>
								{tab.count > 0 && <em class="archive-tab__count">{tab.count}</em>}
							</button>
						</>
					))
				}
			</div>

			<section
				class="archive-section"
				id="section-news"
				data-section="news"
				data-active
				aria-labelledby="head-news"
			>
				<header class="archive-section__head">
					<h2 id="head-news">Новости</h2>
					<span class="archive-section__count">{newsPosts.length} материалов</span>
				</header>
				<div class="archive-list">
					{newsPosts.map((post) => <ArchiveRow post={post} />)}
				</div>
			</section>

			<section
				class="archive-section"
				id="section-analysis"
				data-section="analysis"
				aria-labelledby="head-analysis"
			>
				<header class="archive-section__head">
					<h2 id="head-analysis">Аналитика</h2>
					<span class="archive-section__count">{analysisPosts.length} материалов</span>
				</header>
				<div class="archive-list">
					{analysisPosts.map((post) => <ArchiveRow post={post} />)}
				</div>
			</section>

			<section
				class="archive-section"
				id="section-columns"
				data-section="columns"
				aria-labelledby="head-columns"
			>
				<header class="archive-section__head">
					<h2 id="head-columns">Колонки</h2>
					<span class="archive-section__count">{columnPosts.length} материалов</span>
				</header>
				<div class="archive-list">
					{columnPosts.map((post) => <ArchiveRow post={post} />)}
				</div>
			</section>

			{
				rubricSections.map((section) => (
					<section
						class="archive-section"
						id={`section-${section.id}`}
						data-section={section.id}
						aria-labelledby={`head-${section.id}`}
					>
						<header class="archive-section__head">
							<h2 id={`head-${section.id}`}>{section.label}</h2>
							<span class="archive-section__count">{section.count} материалов</span>
						</header>
						<div class="archive-list">
							{section.posts.map((post) => (
								<ArchiveRow post={post} />
							))}
						</div>
					</section>
				))
			}
		</main>
		<Footer />

		<script is:inline>
			(function () {
				const tabs = document.querySelectorAll('.archive-tab');
				const sections = document.querySelectorAll('[data-section]');
				if (!tabs.length || !sections.length) return;

				function activate(id) {
					let matched = false;
					tabs.forEach((tab) => {
						const isActive = tab.dataset.tab === id;
						tab.classList.toggle('active', isActive);
						tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
						if (isActive) matched = true;
					});
					sections.forEach((section) => {
						const isActive = section.dataset.section === id;
						if (isActive) section.setAttribute('data-active', '');
						else section.removeAttribute('data-active');
					});
					return matched;
				}

				tabs.forEach((tab) => {
					tab.addEventListener('click', () => {
						const id = tab.dataset.tab;
						if (!id) return;
						activate(id);
						const url = new URL(window.location.href);
						url.hash = id;
						history.replaceState(null, '', url.toString());
						window.scrollTo({ top: tab.closest('.archive-tabs').offsetTop - 80, behavior: 'smooth' });
					});
				});

				const initial = window.location.hash ? window.location.hash.slice(1) : '';
				if (!initial || !activate(initial)) {
					activate('news');
				}
			})();
		</script>
	</body>
</html>

<style>
	.archive-page {
		padding-top: 32px;
		padding-bottom: 64px;
	}
	.archive-intro {
		max-width: 760px;
		text-align: center;
		margin: 0 auto 32px;
	}
	.archive-intro__pill {
		display: inline-block;
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 11px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		padding: 5px 12px;
		border-radius: 999px;
		background: var(--violet-50);
		color: var(--violet-600);
		border: 1px solid var(--violet-100);
		margin-bottom: 16px;
	}
	.archive-intro h1 {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 40px;
		line-height: 1.15;
		letter-spacing: -0.025em;
		color: var(--ink-900);
		margin: 0 0 12px;
	}
	.archive-intro p {
		font-family: var(--font-body);
		font-size: 16px;
		line-height: 1.55;
		color: var(--ink-700);
		margin: 0;
	}

	.archive-tabs {
		display: flex;
		gap: 8px;
		flex-wrap: nowrap;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
		padding: 12px 4px;
		margin-bottom: 32px;
		scroll-padding: 12px;
		scrollbar-width: thin;
		scrollbar-color: var(--line-strong) transparent;
		position: sticky;
		top: 88px;
		background: rgba(255, 255, 255, 0.95);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		z-index: 30;
		border-bottom: 1px solid var(--line);
	}
	.archive-tabs::-webkit-scrollbar {
		height: 6px;
	}
	.archive-tabs::-webkit-scrollbar-thumb {
		background: var(--line-strong);
		border-radius: 999px;
	}
	.archive-tabs__divider {
		flex: 0 0 1px;
		height: 22px;
		align-self: center;
		background: var(--line);
		margin: 0 6px;
	}
	.archive-tab {
		flex: 0 0 auto;
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 13px;
		padding: 8px 14px;
		border-radius: 999px;
		border: 1px solid var(--line);
		background: #fff;
		color: var(--ink-900);
		cursor: pointer;
		white-space: nowrap;
		transition: border-color 120ms, background 120ms, color 120ms;
	}
	.archive-tab:hover {
		border-color: var(--line-strong);
		color: var(--violet-600);
	}
	.archive-tab.active {
		background: var(--violet-500);
		border-color: var(--violet-500);
		color: #fff;
	}
	.archive-tab.active:hover {
		background: var(--violet-600);
		border-color: var(--violet-600);
	}
	.archive-tab__count {
		font-style: normal;
		font-family: var(--font-mono);
		font-weight: 500;
		font-size: 11px;
		padding: 2px 7px;
		border-radius: 999px;
		background: var(--paper-2);
		color: var(--ink-500);
	}
	.archive-tab.active .archive-tab__count {
		background: rgba(255, 255, 255, 0.22);
		color: #fff;
	}

	.archive-section {
		display: none;
		margin-bottom: 32px;
		scroll-margin-top: 100px;
	}
	.archive-section[data-active] {
		display: block;
	}
	.archive-section__head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding: 0 0 12px;
		border-bottom: 2px solid var(--ink-900);
		margin-bottom: 8px;
	}
	.archive-section__head h2 {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 24px;
		letter-spacing: -0.015em;
		margin: 0;
		color: var(--ink-900);
	}
	.archive-section__count {
		font-family: var(--font-body);
		font-size: 12px;
		color: var(--ink-500);
	}
	.archive-list :global(.archive-row:last-child) {
		border-bottom: 0;
	}

	@media (max-width: 720px) {
		.archive-intro h1 {
			font-size: 28px;
		}
		.archive-tabs {
			top: 76px;
			padding: 10px 4px;
		}
		.archive-tab {
			font-size: 12px;
			padding: 7px 12px;
		}
	}
</style>
