---
import { getCollection } from 'astro:content';
import ArchiveRow from '../../components/ArchiveRow.astro';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import {
	getClusterConfig,
	getClusterPosts,
	getDeck,
	getHeroAlt,
	getPostHref,
	getVisiblePosts,
	sortPosts,
} from '../../lib/site';
import { buildCollectionPageJsonLd } from '../../lib/structuredData';

export async function getStaticPaths() {
	const posts = sortPosts(getVisiblePosts(await getCollection('posts')));
	const clusters = new Map<string, typeof posts>();
	for (const post of posts) {
		const slug = post.data.storyCluster;
		if (!slug) continue;
		if (!clusters.has(slug)) clusters.set(slug, []);
		clusters.get(slug)!.push(post);
	}
	return [...clusters.entries()]
		.filter(([, list]) => list.length >= 2)
		.map(([slug]) => ({
			params: { slug },
			props: { slug, posts: getClusterPosts(posts, slug) },
		}));
}

const { slug, posts } = Astro.props;
const config = getClusterConfig(slug);
const title = config?.title ?? slug;
const description = config?.description ?? 'Материалы, развивающие одну историю.';
const firstPost = posts[0];
const latestPost = posts[posts.length - 1];
const reversed = [...posts].reverse();
const clusterJsonLd = buildCollectionPageJsonLd({
	title: `${title} — ${SITE_TITLE}`,
	description,
	path: `/cluster/${slug}/`,
	image: latestPost?.data.heroImage ?? firstPost?.data.heroImage,
});
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead
			title={`${title} — ${SITE_TITLE}`}
			description={description}
			image={latestPost?.data.heroImage}
			imageAlt={latestPost ? getHeroAlt(latestPost) : title}
			jsonLd={clusterJsonLd}
		/>
	</head>
	<body>
		<Header />
		<main class="cluster-page container">
			<section class="cluster-hero">
				<span class="cluster-hero__pill">СЮЖЕТ</span>
				<h1>{title}</h1>
				<p>{description}</p>
				<div class="cluster-hero__stats">
					<span><strong>{posts.length}</strong> материалов в одной линии</span>
					{
						firstPost && latestPost && (
							<span>
								от {firstPost.data.pubDate.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' })}
								{' — '}
								до {latestPost.data.pubDate.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' })}
							</span>
						)
					}
				</div>
			</section>

			<section class="cluster-anchors">
				{
					firstPost && (
						<a class="cluster-anchor cluster-anchor--first" href={getPostHref(firstPost)}>
							<span class="cluster-anchor__kicker">Первая публикация</span>
							<strong>{firstPost.data.title}</strong>
							<p>{getDeck(firstPost)}</p>
						</a>
					)
				}
				{
					latestPost && latestPost.id !== firstPost?.id && (
						<a class="cluster-anchor cluster-anchor--latest" href={getPostHref(latestPost)}>
							<span class="cluster-anchor__kicker">Текущая точка</span>
							<strong>{latestPost.data.title}</strong>
							<p>{getDeck(latestPost)}</p>
						</a>
					)
				}
			</section>

			<section class="cluster-timeline" aria-label="Развитие сюжета">
				<header class="cluster-timeline__head">
					<h2>Развитие сюжета</h2>
					<span class="cluster-timeline__hint">сначала свежие</span>
				</header>
				<div class="cluster-timeline__list">
					{
						reversed.map((post, index) => (
							<div class="cluster-timeline__row">
								<div class="cluster-timeline__dot" data-current={index === 0 ? 'true' : null}></div>
								<time class="cluster-timeline__date">
									{post.data.pubDate.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' })}
								</time>
								<div class="cluster-timeline__row-body">
									<ArchiveRow post={post} />
								</div>
							</div>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.cluster-page {
		padding-top: 32px;
		padding-bottom: 64px;
	}
	.cluster-hero {
		max-width: 880px;
		text-align: center;
		margin: 0 auto 32px;
		padding: 32px 24px;
		background: var(--violet-50);
		border: 1px solid var(--violet-100);
		border-radius: 16px;
	}
	.cluster-hero__pill {
		display: inline-block;
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 11px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		padding: 5px 12px;
		border-radius: 999px;
		background: var(--violet-500);
		color: #fff;
		margin-bottom: 16px;
	}
	.cluster-hero h1 {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 44px;
		line-height: 1.1;
		letter-spacing: -0.025em;
		color: var(--ink-900);
		margin: 0 0 14px;
	}
	.cluster-hero p {
		font-family: var(--font-body);
		font-size: 16px;
		line-height: 1.55;
		color: var(--ink-700);
		margin: 0 0 16px;
		max-width: 660px;
		margin-left: auto;
		margin-right: auto;
	}
	.cluster-hero__stats {
		display: flex;
		justify-content: center;
		gap: 24px;
		flex-wrap: wrap;
		font-family: var(--font-body);
		font-size: 13px;
		color: var(--ink-700);
	}
	.cluster-hero__stats strong {
		font-family: var(--font-display);
		font-weight: 700;
		color: var(--ink-900);
	}

	.cluster-anchors {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 16px;
		max-width: 1100px;
		margin: 0 auto 40px;
	}
	.cluster-anchor {
		display: block;
		text-decoration: none;
		color: inherit;
		background: #fff;
		border: 1px solid var(--line);
		border-radius: 12px;
		padding: 20px 22px;
		transition: border-color 120ms, box-shadow 120ms;
	}
	.cluster-anchor:hover {
		border-color: var(--line-strong);
		box-shadow: var(--shadow-1);
	}
	.cluster-anchor--first {
		border-color: var(--violet-100);
		background: var(--violet-50);
	}
	.cluster-anchor--latest {
		border-color: var(--blue-100);
		background: var(--blue-50);
	}
	.cluster-anchor__kicker {
		display: block;
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 11px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--violet-600);
		margin-bottom: 8px;
	}
	.cluster-anchor strong {
		display: block;
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 18px;
		line-height: 1.25;
		color: var(--ink-900);
		margin-bottom: 8px;
	}
	.cluster-anchor p {
		font-family: var(--font-body);
		font-size: 14px;
		line-height: 1.5;
		color: var(--ink-700);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.cluster-timeline {
		max-width: 1100px;
		margin: 0 auto;
	}
	.cluster-timeline__head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		border-bottom: 2px solid var(--ink-900);
		padding-bottom: 12px;
		margin-bottom: 8px;
	}
	.cluster-timeline__head h2 {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 22px;
		margin: 0;
		color: var(--ink-900);
	}
	.cluster-timeline__hint {
		font-family: var(--font-body);
		font-size: 12px;
		color: var(--ink-500);
	}
	.cluster-timeline__list {
		position: relative;
	}
	.cluster-timeline__list::before {
		content: '';
		position: absolute;
		left: 7px;
		top: 12px;
		bottom: 12px;
		width: 1px;
		background: var(--line);
	}
	.cluster-timeline__row {
		display: grid;
		grid-template-columns: 16px 140px 1fr;
		gap: 12px;
		padding: 8px 0;
		align-items: start;
	}
	.cluster-timeline__dot {
		width: 14px;
		height: 14px;
		border-radius: 50%;
		background: #fff;
		border: 2px solid var(--line-strong);
		margin-top: 28px;
		position: relative;
		z-index: 1;
	}
	.cluster-timeline__dot[data-current='true'] {
		background: var(--violet-500);
		border-color: var(--violet-500);
		box-shadow: 0 0 0 4px var(--violet-100);
	}
	.cluster-timeline__date {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--ink-500);
		font-weight: 500;
		padding-top: 28px;
	}
	.cluster-timeline__row-body :global(.archive-row) {
		border-bottom: 1px solid var(--line);
	}

	@media (max-width: 720px) {
		.cluster-hero h1 {
			font-size: 30px;
		}
		.cluster-anchors {
			grid-template-columns: 1fr;
		}
		.cluster-timeline__row {
			grid-template-columns: 16px 1fr;
		}
		.cluster-timeline__date {
			grid-column: 2;
			padding-top: 0;
			padding-bottom: 6px;
			margin-top: -6px;
		}
		.cluster-timeline__row-body {
			grid-column: 2;
		}
	}
</style>
