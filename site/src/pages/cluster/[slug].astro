---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostThumbnail from '../../components/PostThumbnail.astro';
import RubricLabel from '../../components/RubricLabel.astro';
import TickerBar from '../../components/TickerBar.astro';
import { SITE_TITLE } from '../../consts';
import { SITE_CURATION } from '../../data/curation';
import {
	getArticleTypeLabel,
	getClusterConfig,
	getClusterPosts,
	getCuratedPost,
	getDeck,
	getHeroAlt,
	getPostHref,
	getPrimaryRubric,
	getReadingTimeLabel,
	getVisiblePosts,
	isPremiumReadyPost,
	sortPosts,
	sortPostsForPresentation,
} from '../../lib/site';
import { buildCollectionPageJsonLd } from '../../lib/structuredData';

export async function getStaticPaths() {
	const posts = sortPosts(getVisiblePosts(await getCollection('posts')));
	const clusters = new Map<string, typeof posts>();
	for (const post of posts) {
		const slug = post.data.storyCluster;
		if (!slug) continue;
		if (!clusters.has(slug)) clusters.set(slug, []);
		clusters.get(slug)!.push(post);
	}
	return [...clusters.entries()]
		.filter(([, list]) => list.length >= 2)
		.map(([slug]) => ({
			params: { slug },
			props: { slug, posts: getClusterPosts(posts, slug) },
		}));
}

const { slug, posts } = Astro.props;
const config = getClusterConfig(slug);
const title = config?.title ?? slug;
const description = config?.description ?? 'Материалы, развивающие одну историю.';
const firstPost = posts[0];
const latestPost = posts[posts.length - 1];
const spotlight =
	getCuratedPost(posts, SITE_CURATION.clusterSpotlightBySlug[slug], isPremiumReadyPost) ??
	sortPostsForPresentation(posts.filter((post) => isPremiumReadyPost(post) && post.data.articleType !== 'news'))[0] ??
	latestPost;
const clusterJsonLd = buildCollectionPageJsonLd({
	title: `${title} — ${SITE_TITLE}`,
	description,
	path: `/cluster/${slug}/`,
	image: spotlight?.data.heroImage ?? latestPost?.data.heroImage,
});

const roleLabel = (index: number, total: number) => {
	if (index === 0) return 'Первая публикация';
	if (index === total - 1) return 'Последнее обновление';
	return 'Развитие';
};
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead
			title={`${title} — ${SITE_TITLE}`}
			description={description}
			image={spotlight?.data.heroImage ?? latestPost?.data.heroImage}
			imageAlt={spotlight ? getHeroAlt(spotlight) : title}
			jsonLd={clusterJsonLd}
		/>
	</head>
	<body>
		<Header />
		<TickerBar />
		<main class="main-shell">
			<section class="cluster-hero">
				<p class="section-kicker">Сюжет</p>
				<h1 class="cluster-hero__title">{title}</h1>
				{description && <p class="cluster-hero__desc">{description}</p>}
				<div class="cluster-hero__meta">
					<span>{posts.length} материалов</span>
					<a href="/blog" class="cluster-hero__back">← Архив</a>
				</div>
			</section>

			{spotlight && (
				<article class="lead-story lead-story--cluster">
					<PostThumbnail post={spotlight} className="lead-story__media" loading="eager" />
					<div class="lead-story__body">
						<div class="lead-story__meta">
							<span class="content-tag"><RubricLabel name={getPrimaryRubric(spotlight)} /></span>
							<span>{getArticleTypeLabel(spotlight)}</span>
							<span>{getReadingTimeLabel(spotlight)}</span>
						</div>
						<h2 class="lead-story__title">
							<a href={getPostHref(spotlight)}>{spotlight.data.title}</a>
						</h2>
						<p class="lead-story__desc">{getDeck(spotlight)}</p>
					</div>
				</article>
			)}

			<section class="signal-board cluster-summary-grid">
				<div class="signal-board__grid">
					{firstPost && (
						<a class="signal-board__item" href={getPostHref(firstPost)}>
							<span class="signal-board__kicker">С чего началось</span>
							<strong>{firstPost.data.title}</strong>
							<p>{getDeck(firstPost)}</p>
						</a>
					)}
					{latestPost && (
						<a class="signal-board__item" href={getPostHref(latestPost)}>
							<span class="signal-board__kicker">Где сюжет сейчас</span>
							<strong>{latestPost.data.title}</strong>
							<p>{getDeck(latestPost)}</p>
						</a>
					)}
					<div class="signal-board__item">
						<span class="signal-board__kicker">Что изменилось</span>
						<strong>{posts.length} публикаций в одной линии</strong>
						<p>{description}</p>
					</div>
				</div>
			</section>

			<section class="cluster-timeline">
				{posts.map((post, index) => (
					<article class="cluster-timeline__item">
						<div class="cluster-timeline__marker">
							<time>
								{post.data.pubDate.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long' })}
							</time>
							<span class="cluster-timeline__role">{roleLabel(index, posts.length)}</span>
						</div>
						<div class="cluster-timeline__body">
							<PostThumbnail post={post} className="cluster-timeline__thumb" />
							<div>
								<div class="archive-feed__meta">
									<span class="content-tag"><RubricLabel name={getPrimaryRubric(post)} /></span>
									<span>{getArticleTypeLabel(post)}</span>
									<span>{getReadingTimeLabel(post)}</span>
								</div>
								<h2 class="cluster-timeline__title">
									<a href={getPostHref(post)}>{post.data.title}</a>
								</h2>
								<p>{getDeck(post)}</p>
							</div>
						</div>
					</article>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>
