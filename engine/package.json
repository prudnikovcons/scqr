{
  "name": "@scqr/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SCQR editorial engine — signal collection, pipeline, SQLite state, CLI commands.",
  "bin": {
    "scqr": "./src/cli.ts"
  },
  "scripts": {
    "scqr": "tsx src/cli.ts",
    "dev": "tsx watch src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.36.4",
    "jsdom": "^25.0.1",
    "nanoid": "^5.0.9",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "rss-parser": "^3.13.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@mozilla/readability": "^0.5.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
