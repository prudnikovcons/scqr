# SCQR engine — copy to .env.local, fill in values.
# .env and .env.local are gitignored.

# OpenAI (for future Codex-operator visual generation, not used by Claude Code harness directly)
OPENAI_API_KEY=

# GitHub (optional, only if you want engine to open PRs via gh or API)
GITHUB_TOKEN=

# Database (defaults to .scqr/data.db if unset)
SCQR_DB_PATH=

# Site content root (defaults to ../site/src/content/posts relative to engine/)
SCQR_POSTS_PATH=

# Logging level: trace|debug|info|warn|error (default: info)
SCQR_LOG_LEVEL=info
