{
  "name": "scqr-workspace",
  "private": true,
  "version": "0.0.1",
  "description": "SCQR editorial system workspace — Astro site + TypeScript engine for signal collection, review interpretation, article production.",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter site dev",
    "build": "pnpm --filter site build",
    "preview": "pnpm --filter site preview",
    "check": "pnpm --filter site astro check",
    "test": "pnpm --filter engine test",
    "scqr": "pnpm --filter engine exec tsx src/cli.ts",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  }
}
